# Database
DATABASE_URL="mysql://root:@localhost:3306/proxy-manager"

# Redis
REDIS_URL="redis://localhost:6379"

# API Configuration
API_PORT=3001
API_HOST=localhost

# Dashboard Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Agent Configuration
NODE_ID=1
API_URL=http://localhost:3001
REDIS_URL=redis://localhost:6379
DRY_RUN=false

# Security
JWT_SECRET=your-jwt-secret-here
HMAC_SECRET=your-hmac-secret-here

# IPv6 Configuration
IPV6_SUBNET=2001:db8::/64

# 3Proxy Configuration
THREEPROXY_BIN_PATH=/usr/local/bin/3proxy
THREEPROXY_CONFIG_DIR=/etc/3proxy/conf.d
THREEPROXY_PID_FILE=/var/run/3proxy.pid
# Max concurrent connections per proxy (1 = browser automation / 1 account per proxy, 64 = scraping)
PROXY_MAX_CONN=1

# Logging
LOG_LEVEL=info
