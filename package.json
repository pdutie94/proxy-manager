{
  "name": "proxy-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@proxy-manager/dashboard",
    "dev:api": "npm run start:dev --workspace=@proxy-manager/api",
    "dev:agent": "npm run start:dev --workspace=@proxy-manager/agent",
    "build": "npm run build --workspaces",
    "db:generate": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=libs/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=libs/db/prisma/schema.prisma",
    "lint": "npm run lint --workspaces"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tanstack/react-table": "^8.15.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.378.0",
    "next": "^16.2.4",
    "node-cron": "^3.0.3",
    "node-ssh": "^13.2.0",
    "prisma": "^6.19.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
