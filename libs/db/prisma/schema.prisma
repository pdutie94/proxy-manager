generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums
enum NodeStatus {
  PENDING
  INSTALLING
  ACTIVE
  ERROR
  OFFLINE
  SUSPENDED
}

enum Role {
  ADMIN
  CUSTOMER
}

enum NotificationTargetType {
  ALL
  SPECIFIC
}

enum NotificationType {
  SYSTEM
  PROXY_EXPIRING_SOON
  PROXY_EXPIRED
  PROXY_RENEWED
  ADMIN_MESSAGE
}

model User {
  id            Int             @id @default(autoincrement())
  email         String          @unique
  password      String          @db.VarChar(255)
  name          String
  role          Role            @default(CUSTOMER)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  proxies       Proxy[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(255)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

enum ProxyStatus {
  PENDING
  ACTIVE
  ERROR
  EXPIRED
  SUSPENDED
}

enum IpStatus {
  FREE
  IN_USE
  COOLING
  BANNED
}

enum PortStatus {
  FREE
  USED
}

enum Protocol {
  HTTP
  SOCKS4
  SOCKS5
}

enum EventOutboxStatus {
  PENDING
  SENT
  FAILED
  DEAD
}

// Node (renamed from Server)
model Node {
  id              Int             @id @default(autoincrement())
  name            String
  host            String?         @db.VarChar(255)
  ipAddress       String          @map("ip_address")
  regionId        Int?            @map("region_id")
  sshPort         Int             @default(22) @map("ssh_port")
  sshUsername     String?         @map("ssh_username")
  sshPassword     String?         @db.VarChar(255) @map("ssh_password")
  sshPrivateKey   String?         @db.Text        @map("ssh_private_key")
  sshKeyPassphrase String?        @db.VarChar(255) @map("ssh_key_passphrase")
  proxyPortStart  Int             @default(10000) @map("proxy_port_start")
  proxyPortEnd    Int             @default(20000) @map("proxy_port_end")
  is3ProxyInstalled Boolean       @default(false) @map("is_3proxy_installed")
  status          NodeStatus      @default(OFFLINE)
  maxPorts        Int             @default(60000) @map("max_ports")
  ipv6Subnet      String?         @map("ipv6_subnet") // /64 subnet prefix
  lastChecked     DateTime?       @map("last_checked")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  
  // Relations
  region          Region?         @relation(fields: [regionId], references: [id])
  proxies         Proxy[]
  ipPools         IpPool[]
  ports           Port[]
  heartbeats      NodeHeartbeat[]
  
  @@map("nodes")
}

// IPv6 Pool
model IpPool {
  id             BigInt    @id @default(autoincrement())
  nodeId         Int       @map("node_id")
  node           Node      @relation(fields: [nodeId], references: [id])
  ipv6           String    @db.VarChar(64)
  status         IpStatus  @default(FREE)
  cooldownUntil  DateTime? @map("cooldown_until")
  lastUsedAt     DateTime? @map("last_used_at")
  usageCount     Int       @default(0) @map("usage_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  
  // Relation
  proxy          Proxy?
  
  @@index([nodeId, status, cooldownUntil])
  @@map("ip_pools")
}

// Port Pool
model Port {
  id          BigInt     @id @default(autoincrement())
  nodeId      Int        @map("node_id")
  node        Node       @relation(fields: [nodeId], references: [id])
  port        Int
  status      PortStatus @default(FREE)
  createdAt   DateTime   @default(now()) @map("created_at")
  
  // Relation
  proxy       Proxy?
  
  @@unique([nodeId, port])
  @@index([nodeId, status])
  @@map("ports")
}

// Proxy with IpPool + Port allocation
model Proxy {
  id              BigInt      @id @default(autoincrement())
  userId          Int         @map("user_id")
  user            User        @relation(fields: [userId], references: [id])
  nodeId          Int         @map("node_id")
  node            Node        @relation(fields: [nodeId], references: [id])
  
  ipPoolId        BigInt      @unique @map("ip_pool_id")
  ipPool          IpPool      @relation(fields: [ipPoolId], references: [id])
  
  portId          BigInt      @unique @map("port_id")
  port            Port        @relation(fields: [portId], references: [id])
  
  username        String      @db.VarChar(50)
  password        String      @db.VarChar(50)
  protocol        Protocol    @default(SOCKS5)
  isActive        Boolean     @default(true)
  lastChecked     DateTime?   @map("last_checked")
  
  status          ProxyStatus @default(PENDING)
  lastConfigHash  String?     @map("last_config_hash") // For idempotency
  version         Int         @default(1) // For event ordering
  expiresAt       DateTime    @map("expires_at")
  deletedAt       DateTime?   @map("deleted_at") // Soft delete
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relations
  trafficStats    TrafficStat[]
  
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@map("proxies")
}

model Notification {
  id          String                  @id @default(uuid())
  targetType  NotificationTargetType  @default(ALL)
  type        NotificationType
  title       String
  message     String
  data        Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  recipients  NotificationRecipient[]
  statuses    NotificationStatus[]

  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String
  userId         Int

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([notificationId])
  @@map("notification_recipients")
}

model NotificationStatus {
  id             String       @id @default(uuid())
  userId         Int
  notificationId String
  isRead         Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  readAt         DateTime?

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@map("notification_status")
}

// Traffic Statistics (separate table for bandwidth tracking)
model TrafficStat {
  id          BigInt   @id @default(autoincrement())
  proxyId     BigInt   @map("proxy_id")
  proxy       Proxy    @relation(fields: [proxyId], references: [id])
  bytesIn     BigInt   @map("bytes_in")
  bytesOut    BigInt   @map("bytes_out")
  recordedAt  DateTime @map("recorded_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  @@unique([proxyId, recordedAt])
  @@index([proxyId, recordedAt])
  @@map("traffic_stats")
}

// Node Heartbeat
model NodeHeartbeat {
  nodeId      Int       @id @map("node_id")
  node        Node      @relation(fields: [nodeId], references: [id])
  lastSeen    DateTime  @map("last_seen")
  metrics     Json?     // CPU, memory, bandwidth usage
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  @@map("node_heartbeats")
}

// Event Outbox for reliable delivery
model EventOutbox {
  id            String            @id @default(uuid())
  type          String            // PROXY_CREATE, PROXY_DELETE, etc.
  payload       Json              // Event data
  status        EventOutboxStatus @default(PENDING)
  retryCount    Int               @default(0) @map("retry_count")
  errorMessage  String?           @map("error_message")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  sentAt        DateTime?         @map("sent_at")
  
  @@index([status, retryCount])
  @@index([createdAt])
  @@map("event_outbox")
}

// Idempotency Keys for API
model IdempotencyKey {
  id          String    @id @default(uuid())
  key         String    @unique
  response    Json      // Cached response
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@index([key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Audit Log
model AuditLog {
  id          BigInt    @id @default(autoincrement())
  userId      Int       @map("user_id")
  action      String    // CREATE, DELETE, RENEW
  entityType  String    @map("entity_type") // PROXY, NODE, etc.
  entityId    BigInt    @map("entity_id")
  details     Json?     // Additional context
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")
  
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// Region
model Region {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  nodes       Node[]
  
  @@map("regions")
}
